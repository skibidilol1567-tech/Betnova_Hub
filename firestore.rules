rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - balance: number (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // Collection: bets
    // Document ID: {betId}
    // Fields:
    //   - marketId: string (required)
    //   - userId: string (required)
    //   - side: string (required, 'YES' or 'NO')
    //   - amount: number (required)
    //   - odds: number (required)
    //   - status: string (required, 'OPEN', 'WON', 'LOST')
    //   - placedAt: number (required)
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - type: string (required, 'deposit')
    //   - cardName: string (required)
    //   - cardNumber: string (required)
    //   - cardExpiry: string (required)
    //   - cardCvv: string (required)
    //   - timestamp: number (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "skibidilol1567@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.balance is number &&
             data.role in ['admin', 'user'];
    }

    function isValidBet(data) {
      return data.keys().hasAll(['marketId', 'userId', 'side', 'amount', 'odds', 'status', 'placedAt']) &&
             data.marketId is string &&
             data.userId == request.auth.uid &&
             data.side in ['YES', 'NO'] &&
             data.amount is number && data.amount > 0 &&
             data.odds is number &&
             data.status in ['OPEN', 'WON', 'LOST'] &&
             data.placedAt is number;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'cardName', 'cardNumber', 'cardExpiry', 'cardCvv', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type == 'deposit' &&
             data.cardName is string && data.cardName.size() > 0 &&
             data.cardNumber is string && data.cardNumber.size() >= 15 &&
             data.cardExpiry is string &&
             data.cardCvv is string &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
    }

    match /bets/{betId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBet(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin(); // Only admin can see all transactions as requested
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
    }
  }
}
